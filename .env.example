# 認証パスワード
AUTH_PASSWORD=your-secret-password

# Twilio設定
# https://console.twilio.com で取得
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+81xxxxxxxxxx

# Twilio Status Callback 設定（到達率追跡用）
# 本番では自動で VERCEL_URL が使われるが、ローカル動作確認には ngrok URL などを明示設定
# TWILIO_STATUS_CALLBACK_URL=https://your-ngrok.ngrok.io/api/twilio/status-callback
# ローカルテスト時のみ署名検証をスキップ（本番では true にしないこと）
# TWILIO_SKIP_SIGNATURE_VERIFY=false

# Supabase設定
# https://supabase.com のプロジェクト設定から取得
SUPABASE_URL=https://xxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxx

# スケジュール配信用 Cron エンドポイントの認証シークレット
# 任意の長い乱数文字列を設定（Vercel Cron が Authorization: Bearer で送る）
CRON_SECRET=replace-with-long-random-string
